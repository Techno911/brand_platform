# Copy to .env and fill secrets. .env НЕ коммитим в git.

# --- Postgres ---
POSTGRES_DB=bp
POSTGRES_USER=bp
POSTGRES_PASSWORD=change-me-in-prod

# --- JWT ---
JWT_ACCESS_SECRET=change-me-32-bytes-random
JWT_REFRESH_SECRET=change-me-32-bytes-random

# --- Anthropic (reseller-ключ ЧиП) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- S3 (MinIO в dev) ---
MINIO_ROOT_USER=bp-admin
MINIO_ROOT_PASSWORD=bp-admin-local-password
S3_BUCKET_IMMUTABLE=bp-immutable

# --- docx-exporter mTLS (dev — ./infra/exporter/certs/generate-dev-certs.sh) ---
DOCX_EXPORTER_URL=https://bp-docx-exporter:4000
DOCX_TLS_CERT=/certs/server.crt
DOCX_TLS_KEY=/certs/server.key
DOCX_TLS_CLIENT_CA=/certs/ca.crt
DOCX_EXPORTER_CLIENT_CERT=/certs/client.crt
DOCX_EXPORTER_CLIENT_KEY=/certs/client.key
DOCX_EXPORTER_CA_CERT=/certs/ca.crt

# --- Post-MVP adapters (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
ELEVENLABS_API_KEY=
FIREFLIES_API_KEY=

# --- Ingress ports ---
HTTP_PORT=80
HTTPS_PORT=443
