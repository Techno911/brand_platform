# ======================================================
# Brand Platform — backend .env.example
# Copy to .env and fill. NEVER commit .env.
# ======================================================

# --- Server ---
NODE_ENV=development
PORT=3000
# Базовый URL админки — используется в Telegram daily digest'е для deep-link'а.
FRONTEND_URL=https://bp.chirkov.info

# --- Database ---
DATABASE_HOST=bp-postgres
DATABASE_PORT=5432
DATABASE_USER=bp
DATABASE_PASSWORD=change_me_in_prod
DATABASE_NAME=bp
DATABASE_SSL=false

# --- Auth / JWT ---
JWT_ACCESS_SECRET=change_me_access_secret_64chars_min_production
JWT_REFRESH_SECRET=change_me_refresh_secret_64chars_min_production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Anthropic (reseller, only chip_admin sees this key) ---
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_JUDGE_MODEL=claude-haiku-4
ANTHROPIC_MAX_OUTPUT_TOKENS=4096
ANTHROPIC_TIMEOUT_MS=120000

# --- Billing ---
ANTHROPIC_COST_FACTOR=1.0
MARKUP_PERCENT=50
CURRENCY_RATE_USD_RUB=95

# --- AI kill-switch ---
PROJECT_DEFAULT_BUDGET_USD=5.00
DAILY_BUDGET_HARD_CAP_USD=50.00

# --- Golden set regression ---
GOLDEN_SET_REGRESSION_THRESHOLD=0.15

# --- S3 immutable storage ---
S3_ENDPOINT=http://bp-minio:9000
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me
S3_IMMUTABLE_BUCKET=bp-immutable
S3_ASSETS_BUCKET=bp-assets

# --- DOCX exporter microservice ---
DOCX_EXPORTER_URL=http://bp-docx-exporter:4000
DOCX_EXPORTER_CLIENT_CERT=/etc/certs/backend-client.crt
DOCX_EXPORTER_CLIENT_KEY=/etc/certs/backend-client.key
DOCX_EXPORTER_CA_CERT=/etc/certs/ca.crt

# --- Security ---
BRIEF_SANITIZER_MAX_LEN=500000
BRIEF_SANITIZER_FIELD_MAX_LEN=30000
MAX_AGENT_ROUNDTRIPS_PER_STAGE=5

# --- Observability ---
LOG_LEVEL=info
LOG_RETENTION_DAYS=14
GRAFANA_PUSHGATEWAY_URL=http://bp-pushgateway:9091
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- Post-MVP integrations (stubs for now) ---
ELEVENLABS_API_KEY=
FIREFLIES_API_KEY=
